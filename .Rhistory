delivery |>
select(district_name, hosp_type, flag) |>
# 1. Split the table by Hospital Type (Public/Private)
tbl_strata(
strata = hosp_type,
.tbl_fun = ~ .x |>
# 2. Within each type, create a summary by ND/CS
tbl_summary(
