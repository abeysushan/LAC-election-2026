names(delivery)
class(cs_adm_dt)
class(delivery$cs_adm_dt)
# 1. Create the Length of Stay (LOS) variable and generate the table
delivery |>
# difftime ensures the calculation is strictly in days, accounting for timezones
mutate(
los_days = as.numeric(difftime(cs_dis_dt, cs_adm_dt, units = "days"))
) |>
select(hosp_type, flag, los_days) |>
tbl_strata(
strata = hosp_type,
.tbl_fun = ~ .x |>
tbl_summary(
by = flag,
type = list(los_days ~ "continuous"),
# Customizing the output to show Median and Interquartile Range
statistic = list(los_days ~ "{median} ({p25}, {p75})"),
label = list(los_days ~ "Length of Stay (Days)")
) |>
modify_header(all_stat_cols() ~ "**{level}**")
) |>
modify_caption("**Median Length of Stay by Institution and Delivery Type**") |>
bold_labels()
library(ggplot2)
# 2. Generate the faceted box-plots
delivery |>
mutate(
los_days = as.numeric(difftime(cs_dis_dt, cs_adm_dt, units = "days"))
) |>
# Filtering out negative days (data entry errors) if they exist in the raw data
filter(los_days >= 0) |>
ggplot(aes(x = flag, y = los_days, fill = flag)) +
geom_boxplot(alpha = 0.7, outlier.color = "red", outlier.alpha = 0.5) +
# This splits the plot into two side-by-side panels for Public and Private
facet_wrap(~ hosp_type) +
theme_minimal(base_size = 14) +
scale_fill_manual(values = c("ND" = "#4C72B0", "CS" = "#C44E52")) +
labs(
title = "Length of Stay Distribution",
subtitle = "Comparing Normal Deliveries vs. C-Sections across Sectors",
x = "Delivery Type",
y = "Days Admitted",
fill = "Delivery Type"
) +
theme(
legend.position = "bottom",
panel.grid.major.x = element_blank()
)
