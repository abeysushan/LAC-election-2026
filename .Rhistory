percent = "row", # Gives % of ND/CS within that District & Hosp Type
label = list(district_name ~ "District")
)
library(gtsummary)
library(dplyr)
delivery |>
select(district_name, hosp_type, flag) |>
# 1. Split the table by Hospital Type (Public/Private)
tbl_strata(
