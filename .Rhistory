library(tidyverse)
library(googlesheets4)
library(janitor)
library(sf)
library(leaflet)
library(htmltools)
library(htmlwidgets)
sheets_url <- "https://docs.google.com/spreadsheets/d/e/2PACX-1vQU23ns7jeJxqs93ivRVlTTSOss6sKFdclWC0Wajc7mrbJIhnITnLgrUpTzXVFuSq4ikfzlwzJUL2I0/pub?gid=513083881&single=true&output=csv"
results <- read_csv(sheets_url)
map <- st_read("data/KeralaLAC.geojson")
setwd("~/Documents/GitHub/LAC-election-2026")
map <- st_read("data/KeralaLAC.geojson")
map_results <- map |>
left_join(results, by = "Asmbly_Con")
ggplot(map_results) +
geom_sf(aes(fill = Win), color = "black", size = 0.1) +
scale_fill_manual(values = c(
"LDF" = "red",
"UDF" = "lightblue",
"NDA" = "#F1C338",
"OTH" = "grey",
"NA" = "white"
)) +
theme_void()
m <- leaflet(map_results, height = "90vh") |>
addTiles() |>
addPolygons(
fillColor = ~ case_when(
Win == "LDF" ~ "red",
Win == "UDF" ~ "lightblue",
Win == "NDA" ~ "#F1C338",
Win == "OTH" ~ "grey",
TRUE ~ "white"
),
color = "black",
weight = 0.8,
fillOpacity = 0.7,
popup = ~ paste0(
"<strong>", Asmbly_Con, "</strong><br>",
"Winner: ", Win
)
)
m
sum(is.na(map_results$Win))
